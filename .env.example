# PostgreSQL / TimescaleDB + PostGIS
POSTGRES_DB=cerebrovial
POSTGRES_USER=cerebrovial
POSTGRES_PASSWORD=changeme

# URL consumida por la app (host = nombre del servicio en docker-compose)
# Importante: el hostname debe coincidir con el nombre del servicio en docker-compose.yml
DATABASE_URL=postgresql://cerebrovial:changeme@db:5432/cerebrovial
