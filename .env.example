# =============================================================================
# CerebroVial — variables de entorno
# =============================================================================
# Copia este archivo a .env y reemplazá los valores marcados con "changeme".
# Las variables marcadas como (obligatoria) deben estar presentes; el resto
# tiene defaults razonables si se omiten.

# -----------------------------------------------------------------------------
# PostgreSQL / TimescaleDB + PostGIS  (consumido por el servicio "db")
# -----------------------------------------------------------------------------
POSTGRES_DB=cerebrovial
POSTGRES_USER=cerebrovial
POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# URL de conexión a la BD  (obligatoria — consumida por backend y por Alembic)
# -----------------------------------------------------------------------------
# IMPORTANTE: el hostname debe coincidir con el nombre del servicio en
# docker-compose.yml ("db"). Cuando Alembic o seed.py se ejecutan FUERA del
# container (en un venv local), el código reemplaza automáticamente "@db:" por
# "@localhost:5432" — así el mismo .env sirve dentro y fuera del container.
DATABASE_URL=postgresql://cerebrovial:changeme@db:5432/cerebrovial

# -----------------------------------------------------------------------------
# Frontend (Vite)  (consumido en build-time y runtime del frontend)
# -----------------------------------------------------------------------------
# URL base que el frontend usa para llamar al core_management_api.
# - En docker (servicio "frontend"): http://localhost:8001 funciona porque el
#   navegador del usuario sale a localhost del host.
# - En `npm run dev` local: idem, http://localhost:8001.
# - Si despliegan el frontend con un dominio distinto, sobrescribir acá.
VITE_API_BASE_URL=http://localhost:8001
